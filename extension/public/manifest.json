{
  "manifest_version": 3,
  "name": "TradeMarkk — Trading Journal Companion",
  "version": "1.1.0",
  "description": "Log trades and tick your daily rules without leaving your broker's page. Companion to the open-source TradeMarkk journal.",
  "key": "",
  "minimum_chrome_version": "114",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "TradeMarkk"
  },
  "background": {
    "service_worker": "sw.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "permissions": ["sidePanel", "storage", "scripting", "alarms"],
  "host_permissions": ["https://thetrademarkk.com/*", "http://localhost/*"],
  "optional_host_permissions": ["https://*/*"]
}
